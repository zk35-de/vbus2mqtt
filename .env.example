# Serial port (USB-VBus adapter)
SERIAL_PORT=/dev/ttyUSB0
SERIAL_BAUD=9600

# MQTT broker
MQTT_HOST=192.168.1.10
MQTT_PORT=1883
MQTT_USER=
MQTT_PASS=
MQTT_PREFIX=vbus
MQTT_QOS=0
MQTT_RETAIN=true

# How often to push values (seconds)
PUBLISH_INTERVAL=30

# Logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
