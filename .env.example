# ── Serial device ─────────────────────────────────────────────────────────────
# Leave empty for auto-detection (/dev/ttyUSB0, /dev/ttyACM0, …)
SERIAL_PORT=
SERIAL_BAUD=9600

# ── MQTT broker ───────────────────────────────────────────────────────────────
MQTT_BROKER=tcp://localhost:1883
MQTT_TOPIC_PREFIX=vbus
MQTT_USER=
MQTT_PASS=
MQTT_QOS=0
MQTT_RETAIN=true

# ── Application ───────────────────────────────────────────────────────────────
# How often to push accumulated telemetry to MQTT (Go duration, e.g. 30s, 1m)
PUBLISH_INTERVAL=30s

# Logging: debug | info | warn | error
LOG_LEVEL=info
# Log format: json | text
LOG_FORMAT=json
